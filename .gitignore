# ═══════════════════════════════════════════
#  Maven — build output (NEVER push this)
# ═══════════════════════════════════════════
target/
*.class

# ═══════════════════════════════════════════
#  Log files (NEVER push)
# ═══════════════════════════════════════════
logs/
*.log

# ═══════════════════════════════════════════
#  STS / Eclipse IDE files
#  (your personal IDE config — not needed by others)
# ═══════════════════════════════════════════
.settings/
.classpath
.project
.factorypath

# ═══════════════════════════════════════════
#  IntelliJ IDEA (in case someone else uses it)
# ═══════════════════════════════════════════
.idea/
*.iml

# ═══════════════════════════════════════════
#  JAR / WAR files
# ═══════════════════════════════════════════
*.jar
*.war
*.ear

# ═══════════════════════════════════════════
#  OS generated files
# ═══════════════════════════════════════════
.DS_Store
Thumbs.db